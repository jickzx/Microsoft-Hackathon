PORT=4173
DATABASE_URL=file:./dev.db

# QuestBoard server Azure integration. AI extraction and matching require these values.
AZURE_AI_ENDPOINT=https://YOUR-AZURE-AI-ENDPOINT
AZURE_AI_KEY=replace-with-your-key
AZURE_AI_MODE=azure-openai
AZURE_AI_ROUTE=
AZURE_AI_DEPLOYMENT=gpt-4o
AZURE_AI_API_VERSION=2024-10-21
AZURE_AI_AUTH_HEADER=auto
AZURE_AI_TIMEOUT_MS=30000

# Direct Azure OpenAI configuration
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=replace-with-your-key
AZURE_OPENAI_API_KEY_FILE=token_local.js
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_MODEL=gpt-5.4
AZURE_OPENAI_API_VERSION=2024-12-01-preview

QUEST_SCRAPE_TIMEOUT_MS=8000
QUEST_SCRAPE_MAX_BYTES=900000
QUEST_SCRAPE_TEXT_CHARS=9000
AZURE_MATCH_ENABLED=true
AZURE_PROFILE_MATCH_ENABLED=true
AZURE_MATCH_ROUTE=
